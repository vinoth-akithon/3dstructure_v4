---
---
<section id="services" class="py-16 bg-slate-100 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header with accent indicators -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <div class="flex items-center justify-center space-x-2 mb-3">
        <span class="w-8 h-0.5 bg-accent"></span>
        <span class="text-xs font-condensed font-extrabold uppercase tracking-widest text-slate-500">TECHNICAL SOLUTIONS</span>
        <span class="w-8 h-0.5 bg-accent"></span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-condensed font-bold text-brand-navy uppercase tracking-tight">
        Comprehensive Steel Detailing & BIM Services
      </h2>
      <p class="text-slate-600 text-sm mt-3 font-sans max-w-xl mx-auto">
        Delivering structural accuracy from conceptual design to the fabrication shop floor.
      </p>
    </div>

    <!-- 3-Column Service Grid (Traditional Rigid Card style with solid borders) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1: BIM & Modeling -->
      <div class="bg-white border-2 border-slate-200 flex flex-col justify-between rounded-none hover:border-brand-blue duration-200">
        <div>
          <!-- Card Header (Dark slate blue banner) -->
          <div class="bg-brand-blue text-white p-6 relative">
            <div class="absolute top-6 right-6 text-accent">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <span class="text-[10px] font-condensed font-bold tracking-widest uppercase text-slate-300">01 / SOFTWARE INTELLIGENCE</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight mt-1">BIM & 3D Modeling</h3>
          </div>
          
          <div class="p-6 space-y-4">
            <p class="text-xs text-slate-500 leading-relaxed font-sans">
              Advanced parametric modeling using industry-standard Tekla software, enabling clash-free coordination and constructability checks.
            </p>
            
            <ul class="space-y-2.5 pt-2">
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Advanced 3D BIM Modeling</strong> - Full parametric steel geometry built to structural engineering specifications.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Clash Detection & Coordination</strong> - Resolve conflicts early between steel framework, concrete slab, MEP infrastructure.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Model Sharing & Collaboration</strong> - Multi-user environment for seamless structural reviews.</span>
              </li>
            </ul>
          </div>
        </div>
        

      </div>

      <!-- Card 2: Drawing Deliverables -->
      <div class="bg-white border-2 border-slate-200 flex flex-col justify-between rounded-none hover:border-brand-blue duration-200">
        <div>
          <!-- Card Header -->
          <div class="bg-brand-blue text-white p-6 relative">
            <div class="absolute top-6 right-6 text-accent">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <span class="text-[10px] font-condensed font-bold tracking-widest uppercase text-slate-300">02 / SHOP FABRICATION</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight mt-1">Drawing Deliverables</h3>
          </div>
          
          <div class="p-6 space-y-4">
            <p class="text-xs text-slate-500 leading-relaxed font-sans">
              Precision 2D shop and erection drawings extracted directly from the 3D model, ensuring 100% correlation and structural accuracy.
            </p>
            
            <ul class="space-y-2.5 pt-2">
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>General Arrangement (GA)</strong> - High-level layout plans, elevations, section cuts for structural visualization.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Assembly & Single-Part Drawings</strong> - Individual fabrication sheets displaying weld profiles, steel cuts.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Erection Drawings</strong> - Field layouts for site rigging teams, detailing bolt placement, field weld positions.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Sub-Assembly Drawings</strong> - Specialized layouts for secondary steel brackets, trusses, stairways, handrails.</span>
              </li>
            </ul>
          </div>
        </div>
        

      </div>

      <!-- Card 3: Fabrication Documentation -->
      <div class="bg-white border-2 border-slate-200 flex flex-col justify-between rounded-none hover:border-brand-blue duration-200">
        <div>
          <!-- Card Header -->
          <div class="bg-brand-blue text-white p-6 relative">
            <div class="absolute top-6 right-6 text-accent">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
            <span class="text-[10px] font-condensed font-bold tracking-widest uppercase text-slate-300">03 / SHOP AUTOMATION</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight mt-1">Fabrication Documentation</h3>
          </div>
          
          <div class="p-6 space-y-4">
            <p class="text-xs text-slate-500 leading-relaxed font-sans">
              Exporting precise technical lists and automation files directly to shop floor machines to minimize human error and material waste.
            </p>
            
            <ul class="space-y-2.5 pt-2">
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Bill of Materials (BOM)</strong> - Advanced lists organizing steel sections, material grades, profiles.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>Technical Summaries</strong> - Material weight summaries and exact bolt lists (diameters, lengths, grades).</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>CNC Files (NC1)</strong> - Directly compatible with beam lines, plate cutting lines, CNC punch systems.</span>
              </li>
              <li class="flex items-start text-xs font-sans text-slate-700">
                <svg class="w-4 h-4 text-accent mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>KISS & FabTrol Files</strong> - Data files designed for structural procurement and production tracking.</span>
              </li>
            </ul>
          </div>
        </div>
        

      </div>

    </div>

    <!-- Extra Bottom compliance badge -->
    <div class="mt-12 bg-white border border-slate-200 p-6 flex flex-col md:flex-row items-center justify-between">
      <div class="flex items-center space-x-4 mb-4 md:mb-0">
        <div class="bg-slate-100 text-brand-navy p-3 border border-slate-200">
          <!-- Shield check icon -->
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <div>
          <h4 class="text-xs font-condensed font-bold uppercase tracking-wider text-brand-navy">ENGINEERING COMPLIANCE ASSURED</h4>
          <p class="text-[11px] text-slate-500 font-sans mt-0.5">
            Every deliverable complies with Australian Building Codes, standard <strong>AS 4100</strong> (Steel Structures) and drafting code <strong>AS 1100.</strong>
          </p>
        </div>
      </div>
      <div class="flex items-center space-x-3 text-slate-400 font-condensed text-[11px] font-bold">
        <span>PROJECT MANAGEMENT</span>
        <span>•</span>
        <span>CLASH RESOLUTION</span>
        <span>•</span>
        <span>REWORK REDUCTION</span>
      </div>
    </div>

  </div>
</section>
