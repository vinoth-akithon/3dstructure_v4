---
---
<footer class="bg-brand-navy text-slate-350 text-xs py-12 border-t-8 border-accent font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-8 mb-12">
      
      <!-- Column 1: Company Profile (lg:col-span-4) -->
      <div class="lg:col-span-4 space-y-4">
        <div class="flex items-center">
          <img src="/3dstructure-logo.png" alt="3D Structures" class="h-10 w-auto" />
        </div>
        
        <p class="text-[11px] leading-relaxed text-slate-400">
          3D Structures is a specialist structural steel detailing and BIM modeling firm delivering technically robust, fabrication-ready solutions for complex steel structures. We operate as an extended engineering partner to steel fabricators, EPC contractors, and structural consultants globally.
        </p>

        <div class="text-[10px] text-slate-500 font-mono space-y-1">
          <p>SOFTWARE: Tekla Structures (Robust Capacity)</p>
          <p>COMPLIANCE: AS 4100 / AS 1100 / AS 1657</p>
        </div>
      </div>

      <!-- Column 2: Navigation Links (lg:col-span-2) -->
      <div class="lg:col-span-2 space-y-3">
        <h4 class="font-condensed font-bold uppercase tracking-wider text-white text-sm">
          Sitemap
        </h4>
        <ul class="space-y-2">
          <li><a href="#about" class="text-slate-400 hover:text-accent duration-200">About Us</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">Services</a></li>
          <li><a href="#process" class="text-slate-400 hover:text-accent duration-200">Our Process</a></li>
          <li><a href="#industries" class="text-slate-400 hover:text-accent duration-200">Industries</a></li>
          <li><a href="#projects" class="text-slate-400 hover:text-accent duration-200">Projects</a></li>
          <li><a href="#quality" class="text-slate-400 hover:text-accent duration-200">Quality Control</a></li>
        </ul>
      </div>

      <!-- Column 3: Services Summary (lg:col-span-2) -->
      <div class="lg:col-span-2 space-y-3">
        <h4 class="font-condensed font-bold uppercase tracking-wider text-white text-sm">
          Solutions
        </h4>
        <ul class="space-y-2">
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">BIM 3D Modeling</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">GA Drawings</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">Assembly Drawings</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">Single-Part Plans</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">CNC NC1 Files</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-accent duration-200">KISS Lists</a></li>
        </ul>
      </div>

      <!-- Column 4: Offices (lg:col-span-4) -->
      <div class="lg:col-span-4 space-y-4">
        <h4 class="font-condensed font-bold uppercase tracking-wider text-white text-sm">
          Office Location
        </h4>
        
        <div class="space-y-3 text-[11px] leading-relaxed text-slate-400">
          <div>
            <strong class="text-white block font-condensed font-bold uppercase text-xs tracking-wider">Australian Office</strong>
            <span>42b Synnot Street, Werribee, VIC 3030</span>
          </div>
          <div>
            <strong class="text-white block font-condensed font-bold uppercase text-xs tracking-wider">Email Contact</strong>
            <span><a href="mailto:info@3dstructure.com.au" class="hover:text-accent duration-200">info@3dstructure.com.au</a></span>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom sub-footer details -->
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center text-[10px] text-slate-500">
      <div class="mb-4 md:mb-0 text-center md:text-left">
        &copy; {new Date().getFullYear()} 3D Structures Pty Ltd. All Rights Reserved.
      </div>
      <div class="flex space-x-6">
        <span>AS 4100 Compliant Steel Drafting</span>
        <span class="text-slate-700">|</span>
        <span>Secure Digital Collaboration</span>
      </div>
    </div>
  </div>
</footer>
