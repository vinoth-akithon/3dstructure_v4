---
---
<section id="industries" class="py-16 bg-slate-100 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <div class="flex items-center justify-center space-x-2 mb-3">
        <span class="w-8 h-0.5 bg-accent"></span>
        <span class="text-xs font-condensed font-extrabold uppercase tracking-widest text-slate-500">MARKET SECTORS</span>
        <span class="w-8 h-0.5 bg-accent"></span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-condensed font-bold text-brand-navy uppercase tracking-tight">
        Sectors We Serve
      </h2>
      <p class="text-slate-600 text-sm mt-3 font-sans max-w-xl mx-auto">
        Providing custom structural detailing solutions optimized for distinct industrial, resources, and civil applications.
      </p>
    </div>

    <!-- 6-Sector Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- 1. Industrial Structures -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div class="flex flex-col">
          <img src="industrial-structure.png" class="w-full h-62">
          
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Industrial Structures
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            Detailed design of manufacturing facilities, heavy mineral process plants, conveyor galleries, and machinery support platforms.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: Heavy Machinery Clearance (AS 4100)
        </div>
      </div>

      <!-- 2. Commercial Buildings -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <img src="commercial-building.png" class="w-full h-62">
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Commercial Buildings
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            Multi-story office towers, shopping centers, hotels, and architectural steel stairs/canopies integrated with composite structures.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: High-Rise Coordination (BIM Level 2)
        </div>
      </div>

      <!-- 3. Oil & Gas Facilities -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <img src="oil-gas.png" class="w-full h-62">
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Oil & Gas / Resources
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            Highly standardized designs for offshore platforms, refinery pipe racks, equipment modular skids, and bulk storage gantries.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: Skid Modular Design & Lifting Analysis
        </div>
      </div>

      <!-- 4. Power & Energy Projects -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <img src="power-energy.png" class="w-full h-62">
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Power & Energy Infrastructure
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            Substations, switchyard structures, wind turbine steel frames, battery enclosure foundations, and cable bridge pathways.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: High-Voltage Clearance & Wind Load Standards
        </div>
      </div>

      <!-- 5. Warehouses & Logistics -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <img src="warehouse.png" class="w-full h-62">
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Warehouses & Logistics
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            High-span distribution depots, loading docks, cold-storage portals, mezzanine floors, and heavy storage racks.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: Portal Frame Optimization (AS 4100)
        </div>
      </div>

      <!-- 6. Miscellaneous & Architectural Steel -->
      <div class="bg-white border border-slate-250 p-6 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <img src="miscellaneous.png" class="w-full h-62">
          <h3 class="text-lg font-condensed font-bold uppercase tracking-wide text-brand-navy">
            Miscellaneous & Architectural Steel
          </h3>
          <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
            Detailed drawings for access ladders, walkways, handrails, architectural egress stairs, lintels, and site-welded brackets.
          </p>
        </div>
        <div class="text-[10px] font-mono text-slate-400 mt-4 border-t border-slate-100 pt-2">
          COMPLIANCE: Handrail & Stair Balustrade Codes (AS 1657)
        </div>
      </div>

    </div>

  </div>
</section>
