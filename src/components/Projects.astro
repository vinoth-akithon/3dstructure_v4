---
---
<section id="projects" class="py-16 bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <div class="flex items-center justify-center space-x-2 mb-3">
        <span class="w-8 h-0.5 bg-accent"></span>
        <span class="text-xs font-condensed font-extrabold uppercase tracking-widest text-slate-500">PROJECT CAPABILITY</span>
        <span class="w-8 h-0.5 bg-accent"></span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-condensed font-bold text-brand-navy uppercase tracking-tight">
        Featured Detailing Projects
      </h2>
      <p class="text-slate-600 text-sm mt-3 font-sans max-w-xl mx-auto">
        Demonstrated capacity in delivering high-volume, highly complex steel packages compliant with local standards.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Project 1: Port of Brisbane Logistics Hub -->
      <div class="bg-slate-50 border border-slate-200 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <!-- Blueprint / CAD SVG representation of Logistics Hub -->
          <div class="w-full h-48 bg-slate-900 text-slate-400 p-4 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute inset-0 blueprint-grid-dark opacity-10"></div>
            <div class="flex justify-between items-start z-10">
              <span class="text-[8px] font-mono text-slate-500">DRW NO: BNE-LOG-GA-001</span>
              <span class="bg-accent text-white text-[8px] font-condensed uppercase tracking-wider px-2 py-0.5">COMPLETED</span>
            </div>
            
            <!-- SVG Portal Frame -->
            <svg viewBox="0 0 200 100" class="w-full h-24 text-slate-400 z-10 mx-auto" fill="none" stroke="currentColor" stroke-width="1">
              <!-- Grid lines -->
              <line x1="20" y1="90" x2="180" y2="90" stroke="rgba(255,255,255,0.1)" />
              <line x1="30" y1="90" x2="30" y2="40" stroke="#cbd5e1" stroke-width="1.5" />
              <line x1="170" y1="90" x2="170" y2="40" stroke="#cbd5e1" stroke-width="1.5" />
              <line x1="30" y1="40" x2="100" y2="20" stroke="#cbd5e1" stroke-width="1.5" />
              <line x1="100" y1="20" x2="170" y2="40" stroke="#cbd5e1" stroke-width="1.5" />
              <!-- Haunch details -->
              <polygon points="30,40 30,48 45,43" fill="#ea580c" stroke="none" />
              <polygon points="170,40 170,48 155,43" fill="#ea580c" stroke="none" />
              <polygon points="100,20 100,28 90,23 110,23" fill="#ea580c" stroke="none" />
              <!-- Dimension lines -->
              <line x1="30" y1="95" x2="170" y2="95" stroke="#ea580c" stroke-width="0.75" stroke-dasharray="2,2" />
              <line x1="30" y1="92" x2="30" y2="98" stroke="#ea580c" stroke-width="0.75" />
              <line x1="170" y1="92" x2="170" y2="98" stroke="#ea580c" stroke-width="0.75" />
              <text x="90" y="93" fill="#ea585c" font-size="6" font-family="monospace">SPAN: 38,000 mm</text>
            </svg>
            
            <div class="text-[8px] font-mono text-slate-500 z-10 flex justify-between">
              <span>PROJECT CODE: P-2024-BNE</span>
              <span>SCALE: 1:150</span>
            </div>
          </div>

          <!-- Project Description -->
          <div class="p-6">
            <span class="text-[9px] uppercase font-bold text-accent font-sans">1,450 TONNES • LOGISTICS WAREHOUSE</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight text-brand-navy mt-1">
              Port of Brisbane Logistics Hub
            </h3>
            <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
              Complete detailing of a multi-bay industrial distribution center. Deliverables included portal framing, purlins/girts coordination, high-span rafters, complex mezzanine floor slabs, and external canopy framing details.
            </p>
            
            <!-- Metadata table -->
            <div class="mt-4 pt-4 border-t border-slate-200 grid grid-cols-2 gap-y-2 text-[11px] font-sans text-slate-600">
              <div><strong>Location:</strong> Brisbane, QLD</div>
              <div><strong>Client:</strong> Tier-1 Steel Fabricator</div>
              <div><strong>Software:</strong> Tekla Structures</div>
              <div><strong>Standard:</strong> AS 4100 / AS 1554</div>
            </div>
          </div>
        </div>
        
        <div class="p-6 pt-0">
          <div class="border-t border-slate-200 pt-4 flex justify-between items-center text-xs">
            <span class="font-condensed font-bold text-brand-navy">SCOPE: MODELING & SHOP DRAWINGS</span>
          </div>
        </div>
      </div>

      <!-- Project 2: Sydney Egress Stair Tower -->
      <div class="bg-slate-50 border border-slate-200 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <!-- Blueprint / CAD SVG representation of Stair Tower -->
          <div class="w-full h-48 bg-slate-900 text-slate-400 p-4 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute inset-0 blueprint-grid-dark opacity-10"></div>
            <div class="flex justify-between items-start z-10">
              <span class="text-[8px] font-mono text-slate-500">DRW NO: SYD-STR-EL-012</span>
              <span class="bg-accent text-white text-[8px] font-condensed uppercase tracking-wider px-2 py-0.5">COMPLETED</span>
            </div>
            
            <!-- SVG Stair Outline -->
            <svg viewBox="0 0 200 100" class="w-full h-24 text-slate-400 z-10 mx-auto" fill="none" stroke="currentColor" stroke-width="1">
              <!-- Landing 1 -->
              <line x1="20" y1="80" x2="60" y2="80" stroke="#cbd5e1" stroke-width="2" />
              <!-- Stairs Flight 1 -->
              <line x1="60" y1="80" x2="120" y2="40" stroke="#cbd5e1" stroke-width="2" />
              <!-- Landing 2 -->
              <line x1="120" y1="40" x2="160" y2="40" stroke="#cbd5e1" stroke-width="2" />
              
              <!-- Treads representation -->
              <line x1="70" y1="73.3" x2="80" y2="73.3" stroke="#ea580c" />
              <line x1="80" y1="66.6" x2="90" y2="66.6" stroke="#ea580c" />
              <line x1="90" y1="60" x2="100" y2="60" stroke="#ea580c" />
              <line x1="100" y1="53.3" x2="110" y2="53.3" stroke="#ea580c" />
              
              <!-- Dimension details -->
              <line x1="170" y1="80" x2="170" y2="40" stroke="#ea580c" stroke-width="0.75" />
              <line x1="167" y1="80" x2="173" y2="80" stroke="#ea580c" stroke-width="0.75" />
              <line x1="167" y1="40" x2="173" y2="40" stroke="#ea580c" stroke-width="0.75" />
              <text x="175" y="63" fill="#ea585c" font-size="6" font-family="monospace">RISE: 3,200 mm</text>
            </svg>
            
            <div class="text-[8px] font-mono text-slate-500 z-10 flex justify-between">
              <span>PROJECT CODE: P-2025-SYD</span>
              <span>SCALE: 1:75</span>
            </div>
          </div>

          <!-- Project Description -->
          <div class="p-6">
            <span class="text-[9px] uppercase font-bold text-accent font-sans">180 TONNES • MISCELLANEOUS STRUCTURAL</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight text-brand-navy mt-1">
              Sydney High-Rise Egress Core
            </h3>
            <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
              Highly complex 3D modeling and shop drawings for internal core egress stair structures spanning 12 levels. High-precision alignment required to integrate with precast concrete wall pockets and standard building services layout.
            </p>
            
            <!-- Metadata table -->
            <div class="mt-4 pt-4 border-t border-slate-200 grid grid-cols-2 gap-y-2 text-[11px] font-sans text-slate-600">
              <div><strong>Location:</strong> Sydney, NSW</div>
              <div><strong>Client:</strong> Structural Engineering Firm</div>
              <div><strong>Software:</strong> Tekla Model Sharing</div>
              <div><strong>Standard:</strong> AS 1657 (Access & Stairs)</div>
            </div>
          </div>
        </div>
        
        <div class="p-6 pt-0">
          <div class="border-t border-slate-200 pt-4 flex justify-between items-center text-xs">
            <span class="font-condensed font-bold text-brand-navy">SCOPE: 3D MODELING & FIT ASSURANCE</span>
          </div>
        </div>
      </div>

      <!-- Project 3: Pilbara Resources Process Plant -->
      <div class="bg-slate-50 border border-slate-200 flex flex-col justify-between rounded-none hover:shadow-md transition-all duration-200">
        <div>
          <!-- Blueprint / CAD SVG representation of Pilbara plant -->
          <div class="w-full h-48 bg-slate-900 text-slate-400 p-4 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute inset-0 blueprint-grid-dark opacity-10"></div>
            <div class="flex justify-between items-start z-10">
              <span class="text-[8px] font-mono text-slate-500">DRW NO: PLB-SKD-MD-043</span>
              <span class="bg-accent text-white text-[8px] font-condensed uppercase tracking-wider px-2 py-0.5">COMPLETED</span>
            </div>
            
            <!-- SVG Process Rack -->
            <svg viewBox="0 0 200 100" class="w-full h-24 text-slate-400 z-10 mx-auto" fill="none" stroke="currentColor" stroke-width="1">
              <!-- Skid frame box -->
              <rect x="30" y="30" width="140" height="50" stroke="#cbd5e1" stroke-width="1.5" />
              <!-- Diagonal bracings -->
              <line x1="30" y1="30" x2="100" y2="80" stroke="#ea580c" />
              <line x1="170" y1="30" x2="100" y2="80" stroke="#ea580c" />
              <line x1="30" y1="80" x2="100" y2="30" stroke="#cbd5e1" />
              <line x1="170" y1="80" x2="100" y2="30" stroke="#cbd5e1" />
              <!-- Inner machine base support line -->
              <line x1="30" y1="55" x2="170" y2="55" stroke="#cbd5e1" stroke-width="1.5" />
            </svg>
            
            <div class="text-[8px] font-mono text-slate-500 z-10 flex justify-between">
              <span>PROJECT CODE: P-2024-PLB</span>
              <span>SCALE: 1:100</span>
            </div>
          </div>

          <!-- Project Description -->
          <div class="p-6">
            <span class="text-[9px] uppercase font-bold text-accent font-sans">850 TONNES • INDUSTRIAL RESOURCES</span>
            <h3 class="text-xl font-condensed font-bold uppercase tracking-tight text-brand-navy mt-1">
              Pilbara Ore Processing Facility
            </h3>
            <p class="text-xs text-slate-500 font-sans mt-2 leading-relaxed">
              Detailed shop modeling and drawing package for modular processing skids, high-strength gantry frameworks, equipment support structures, and access walkways exposed to harsh environmental wind loads.
            </p>
            
            <!-- Metadata table -->
            <div class="mt-4 pt-4 border-t border-slate-200 grid grid-cols-2 gap-y-2 text-[11px] font-sans text-slate-600">
              <div><strong>Location:</strong> Pilbara Region, WA</div>
              <div><strong>Client:</strong> Mining EPC Contractor</div>
              <div><strong>Software:</strong> Tekla Structures</div>
              <div><strong>Standard:</strong> AS 4100 / Mining Standards</div>
            </div>
          </div>
        </div>
        
        <div class="p-6 pt-0">
          <div class="border-t border-slate-200 pt-4 flex justify-between items-center text-xs">
            <span class="font-condensed font-bold text-brand-navy">SCOPE: FABRICATION-READY NC FILES</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
